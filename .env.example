# ══════════════════════════════════════════════════════════════
# معالج الصوت الذكي — متغيرات البيئة
# انسخ هذا الملف إلى .env وأضف قيمك الحقيقية
# ══════════════════════════════════════════════════════════════

# ── الخادم ────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── استخراج النص (Whisper API) ────────────────────────────────
# احصل على مفتاحك من: https://platform.openai.com/api-keys
# اختياري — إذا لم تُضفه، ميزة استخراج النص لن تعمل
OPENAI_API_KEY=sk-...

# ── قاعدة البيانات (اختياري) ──────────────────────────────────
# مطلوب فقط إذا فعّلت ميزات المصادقة وحفظ الملفات
# DATABASE_URL=mysql://user:password@host:3306/dbname

# ── التخزين S3 (اختياري) ──────────────────────────────────────
# مطلوب فقط لرفع الملفات على السحابة
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=

# ── المصادقة (اختياري) ────────────────────────────────────────
# مطلوب فقط إذا فعّلت OAuth
# OAUTH_SERVER_URL=
# COOKIE_SECRET=change-this-to-a-random-string-min-32-chars

# ── وضع العميل فقط (نسخة beta محلية) ─────────────────────────
# اضبطه على true لإخفاء عناصر الواجهة المرتبطة بالخادم
# (تسجيل الدخول، تسجيل الخروج، رفع السحابة)
# جميع أدوات الصوت تعمل محلياً بغض النظر عن هذا الإعداد
VITE_CLIENT_ONLY_MODE=false

# ══════════════════════════════════════════════════════════════
# ملاحظة: التطبيق يعمل بدون أي من هذه المتغيرات
# كل معالجة الصوت تتم في المتصفح مباشرةً
# ══════════════════════════════════════════════════════════════
